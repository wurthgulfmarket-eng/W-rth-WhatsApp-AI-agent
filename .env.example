# ===== WhatsApp Meta Cloud API =====
# From developers.facebook.com > your WhatsApp app > API Setup
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
# Any random string you choose, entered when you configure the webhook in Meta's dashboard
WHATSAPP_VERIFY_TOKEN=

# ===== OpenRouter (AI) =====
# From openrouter.ai/keys
OPENROUTER_API_KEY=
# Any chat model available on OpenRouter, e.g. anthropic/claude-sonnet-4.5, openai/gpt-4.1, etc.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Comma-separated fallback models, tried in order if OPENROUTER_MODEL keeps
# failing (e.g. the free-tier provider is at capacity) - spreads load across
# different providers so one being saturated doesn't fail every reply.
OPENROUTER_FALLBACK_MODELS=google/gemma-4-26b-a4b-it:free,openai/gpt-oss-20b:free
# Must be a vision/multimodal-capable model - used only for customer-sent
# photos. A text-only model here silently fails on every image.
OPENROUTER_VISION_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_VISION_FALLBACK_MODELS=nvidia/nemotron-nano-12b-v2-vl:free,google/gemma-4-31b-it:free

# ===== Groq (voice note transcription, optional) =====
# From console.groq.com/keys - transcribes customer voice notes so they get
# a real AI reply instead of "please type your question instead". Leave
# blank to keep that fallback behavior without transcription.
GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# ===== Google Sheets (Sales Rep directory) =====
# Share the sheet with the service account's client_email as Viewer
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json
# Name of the worksheet/tab that holds the rep directory
GOOGLE_SHEET_WORKSHEET_NAME=Sheet1
# Once a customer is matched to a rep, that mapping is cached in Postgres so
# we don't re-ask for their company on every message. This re-checks the
# sheet and refreshes rep_name/rep_phone/rep_email if the cached record is
# older than this many hours - keeps sheet updates (a rep's number
# changing, a rep leaving) flowing to customers already on file.
REP_INFO_REFRESH_HOURS=12

# ===== App =====
# Confidence threshold (0-100) below which a conversation is flagged for human handoff
FUZZY_MATCH_THRESHOLD=85
# Comma-separated phone numbers (with country code, no +) that receive escalation alerts
ESCALATION_NOTIFY_NUMBERS=
# Separate list: notified once when a brand-new contact can't be matched to
# any company at all on their first message (not a rep-notification-failure
# backstop like ESCALATION_NOTIFY_NUMBERS above - a distinct "new unmatched
# lead" alert).
NEW_LEAD_NOTIFY_NUMBERS=
PORT=8000

# ===== Lead escalation WhatsApp templates (optional) =====
# Meta-approved template names for notifying reps/ops of a new lead - bypasses
# the 24-hour free-form-message window. Leave blank until Meta approves your
# template(s); escalation falls back to free-form messages until then.
WHATSAPP_ESCALATION_TEMPLATE_NAME=
WHATSAPP_ESCALATION_TEMPLATE_LANGUAGE=en
WHATSAPP_ESCALATION_OPS_TEMPLATE_NAME=

# ===== Lead dedup + day-1 rep reminder =====
# Escalated messages from the same customer within this many hours collapse
# into one lead on the dashboard instead of one row per message.
LEAD_DEDUP_WINDOW_HOURS=36
# If a lead is still open and the assigned REP hasn't replied to the original
# escalation alert after this many hours, a reminder is sent to the REP (not
# the customer) - requires WHATSAPP_REP_REMINDER_TEMPLATE_NAME to be set
# (Meta-approved template; fires outside the 24h free-form window).
LEAD_FOLLOWUP_HOURS=24
WHATSAPP_REP_REMINDER_TEMPLATE_NAME=
WHATSAPP_REP_REMINDER_TEMPLATE_LANGUAGE=en
